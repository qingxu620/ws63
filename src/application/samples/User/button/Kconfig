#===============================================================================
# User/button/Kconfig

config MY_BUTTON_PIN
    int
    prompt "Choose My Button pin."
    depends on SAMPLE_SUPPORT_MY_BUTTON
    default 14
    help
        Set the GPIO pin number for your button input.

config MY_BUTTON_LED_PIN
    int
    prompt "Choose Button LED pin."
    depends on SAMPLE_SUPPORT_MY_BUTTON
    default 2
    help
        Set the GPIO pin number for the LED controlled by button.
