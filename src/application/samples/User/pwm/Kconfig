#===============================================================================
# User/pwm/Kconfig

config MY_PWM_PIN  # <--- 改名，避免和官方冲突
    int
    prompt "Choose My PWM pin."
    # 下面这一行非常关键：它依赖于父目录定义的开关
    depends on SAMPLE_SUPPORT_MY_PWM 
    default 2
    help
        Set the GPIO pin number for your PWM output.