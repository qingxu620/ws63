config ENABLE_LASER_MARKER_SAMPLE
    bool
    prompt "Enable the Sample of WS63 Laser Marker."
    default n
    depends on SAMPLE_ENABLE
    help
        This option means enable the WS63 Laser Marker sample.

if ENABLE_LASER_MARKER_SAMPLE
source "ws63_test/Kconfig"
endif

config ENABLE_LASER_SINGLE_SAMPLE
    bool
    prompt "Enable the Sample of WS63 Single Board Laser Marker."
    default n
    depends on SAMPLE_ENABLE
    select SPI_SUPPORT_MASTER
    help
        This option means enable a single-board WS63 laser marker sample.
        If both WS63 Laser Marker and this option are enabled, CMake builds
        this single-board sample first.

if ENABLE_LASER_SINGLE_SAMPLE
source "ws63_laser_single/Kconfig"
endif

config ENABLE_LASER_WIRELESS_SAMPLE
    bool
    prompt "Enable the Sample of WS63 Wireless Laser Marker (隔离版无线激光振镜打标机)."
    default n
    depends on SAMPLE_ENABLE
    help
        This option enables the isolated wireless laser marker development tree.
        It is separate from the stable single-board sample.

if ENABLE_LASER_WIRELESS_SAMPLE
choice
    prompt "WS63 Wireless board role (无线板卡角色，决定本次编译哪块板)"
    default LASER_WIRELESS_RECEIVER

config LASER_WIRELESS_RECEIVER
    bool "Build RECEIVER board firmware (接收板：连接振镜/激光，执行打标)"
    select SPI_SUPPORT_MASTER
    help
        Build the receiver-side firmware. The receiver connects to the galvo,
        DAC/SPI and laser PWM output, receives SLE packets from the transmitter,
        and executes motion/laser commands.

config LASER_WIRELESS_TRANSMITTER
    bool "Build TRANSMITTER board firmware (发射板：连接LaserGRBL，转发指令)"
    help
        Build the transmitter-side firmware. The transmitter connects to
        LaserGRBL over UART, parses G-code, and forwards motion packets to the
        receiver over SLE.

endchoice

comment "CURRENT BUILD TARGET: RECEIVER / 接收板固件（烧录到接振镜和激光的板子）"
    depends on LASER_WIRELESS_RECEIVER

comment "CURRENT BUILD TARGET: TRANSMITTER / 发射板固件（烧录到连接LaserGRBL的板子）"
    depends on LASER_WIRELESS_TRANSMITTER

source "ws63_laser_wireless/Kconfig"
endif

config ENABLE_SLE_LASER_SAMPLE
    bool
    prompt "Enable WS63 SLE Laser Marker (SLE无线激光打标 - 极简透传设计)"
    default n
    depends on SAMPLE_ENABLE
    help
        This option enables WS63 SLE laser marker with minimal passthrough design.
        Transmitter: UART->SLE passthrough (no G-code parsing).
        Receiver: Reuses ws63_laser_single logic with SLE input.

if ENABLE_SLE_LASER_SAMPLE
source "ws63_sle_laser/Kconfig"
endif

config ENABLE_LASER_SLE_BRIDGE_SAMPLE
    bool
    prompt "Enable WS63 Laser SLE Bridge (透明无线串口主线方案)."
    default n
    depends on SAMPLE_ENABLE
    help
        This option enables the final-mainline bridge design:
        transmitter is only a transparent UART/SLE bridge, while receiver is
        the only Grbl-compatible laser controller.

if ENABLE_LASER_SLE_BRIDGE_SAMPLE
source "ws63_laser_sle_bridge/Kconfig"
endif

# 注册你的 User 配置菜单
source "application/samples/User/Kconfig"
