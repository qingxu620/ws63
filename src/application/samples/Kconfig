comment "WS63 激光打标工程：串口基线 / WiFi实时 / SLE离线任务"

config ENABLE_LASER_SINGLE_SAMPLE
    bool
    prompt "WS63 串口单板激光打标（有线基线）"
    default n
    depends on SAMPLE_ENABLE
    select SPI_SUPPORT_MASTER
    help
        用途：最稳定的有线串口基线工程。
        电脑通过 USB/串口直接连接接收板，接收板本地完成 G-code 解析、
        振镜运动和激光控制。适合验证底层运动、DAC、PWM、激光关断等核心逻辑。

if ENABLE_LASER_SINGLE_SAMPLE
source "deprecated/ws63_laser_single/Kconfig"
endif

config ENABLE_LASER_WIFI_SAMPLE
    bool
    prompt "WS63 WiFi 实时激光打标（SoftAP/TCP）"
    default n
    depends on SAMPLE_ENABLE
    select SPI_SUPPORT_MASTER
    help
        用途：当前无线实时打标主线工程。
        接收板开启 WiFi SoftAP，并在 TCP 端口提供 Grbl/Telnet 服务。
        LaserGRBL 可通过 IP:PORT 直接连接，适合实时无线打标。

if ENABLE_LASER_WIFI_SAMPLE
source "deprecated/ws63_laser_wifi/Kconfig"
endif

config ENABLE_LASER_SLE_JOB_SAMPLE
    bool
    prompt "WS63 SLE 离线任务包激光打标（TX/RX + 自建上位机）"
    default n
    depends on SAMPLE_ENABLE
    help
        用途：SLE 结构化任务包工程，不兼容 LaserGRBL 实时串口协议。
        PC 自建上位机通过串口把完整 G-code 任务发给 TX，TX 封装为 SLE
        标准包下发给 RX，RX 缓存完整任务、校验通过后本地执行。

if ENABLE_LASER_SLE_JOB_SAMPLE
source "ws63_laser_sle_tx/Kconfig"
endif

config LASER_RX_UNIFIED
    bool
    prompt "WS63 RX 三模融合骨架（USART / WiFi / SLE）"
    default n
    depends on SAMPLE_ENABLE
    select SPI_SUPPORT_MASTER
    help
        用途：新的 route-based 统一 RX 固件主线。目标是最终融合 USART Direct、
        WiFi TCP 和 SLE job packet 三种 route，同时复用入口、route manager、
        safety/status 和构建流程。当前 R1 只编译 route manager stub，不启动真实 route。

if LASER_RX_UNIFIED
source "ws63_laser_rx_unified/Kconfig"
endif

comment "WS63 LVGL 模块：LVGL v9.3.0 + MSP3223 target"

config ENABLE_LVGL_SAMPLE
    bool
    prompt "WS63 LVGL 最小移植（MSP3223 target + LVGL v9.3.0）"
    default n
    depends on SAMPLE_ENABLE
    select SPI_SUPPORT_MASTER
    help
        用途：LVGL v9.3.0 最小移植验证。
        临时复用 deprecated/ws63_screen_st7796_ft6336 的历史 LCD/触摸驱动，
        显示 WS63 Laser Panel demo 页面。
        注意：与 ENABLE_SCREEN_SAMPLE 互斥（共用硬件）。

if ENABLE_LVGL_SAMPLE
source "deprecated/ws63_screen_panel_lvgl/Kconfig"
endif

config ENABLE_LVGL_PANEL
    bool
    prompt "WS63 工业中控面板 UI（MSP3223 target + LVGL v9.3.0）"
    default n
    depends on SAMPLE_ENABLE
    select SPI_SUPPORT_MASTER
    help
        用途：工业风格中控面板 UI，包含进度圆环、状态卡片、动作按钮栏。
        与 ENABLE_LVGL_SAMPLE 互斥（共用硬件和 LVGL）。

if ENABLE_LVGL_PANEL
source "deprecated/ws63_screen_panel_lvgl/Kconfig"
endif

config ENABLE_SD_CARD_TEST
    bool
    prompt "WS63 MSP3223 TF卡独立读取测试（不启动屏幕）"
    default n
    depends on SAMPLE_ENABLE
    select SPI_SUPPORT_MASTER
    help
        用途：只初始化共享 SPI 引脚、SD 卡和 FAT 根目录扫描，不启动
        LCD、LVGL、触摸、SLE 或激光控制，用于排查 MSP3223 板载 TF 卡座、
        MISO/CS/供电/卡格式等问题。
