# =============================================================================
#  WS63 源代码目录 .gitignore
#  针对 src/ 子目录的特定规则
# =============================================================================

# -----------------------------------------------------------------------------
# 构建产物和缓存
# ------------------------------------------------------------------------------

# CMake 构建目录
build/
out/
output/
cmake-build-*/
CMakeFiles/
CMakeCache.txt

# 编译产物
*.o
*.obj
*.elf
*.bin
*.hex
*.map
*.s19
*.a
*.lib
*.so
*.dylib

# 依赖文件
*.d
*.dep

# 编译数据库
compile_commands.json

# ccache 缓存
.ccache/

# -----------------------------------------------------------------------------
# 配置文件
# ------------------------------------------------------------------------------

# 菜单配置文件（构建时生成）
build/config/target_config/ws63/menuconfig/acore/*.config.old
build/config/target_config/ws63/menuconfig/acore/*.config

# 生成的配置头文件
mconfig.h
auto_config.h
generated_config.h

# -----------------------------------------------------------------------------
# Python 相关
# ------------------------------------------------------------------------------

# Python 字节码
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Python 虚拟环境
.venv/
venv/
ENV/
env/

# -----------------------------------------------------------------------------
# 项目特定临时文件
# ------------------------------------------------------------------------------

# 测试生成的临时图像
ws63_test/temp_ai_image.png
ws63_test/temp_contours_preview.png
ws63_test/temp_*.png
ws63_test/temp_*.jpg
ws63_test/temp_*.jpeg

# 测试输出
test_output/
test_results/

# 文档生成
docs/_build/

# -----------------------------------------------------------------------------
# 开发工具
# ------------------------------------------------------------------------------

# IDE 配置
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Windows NTFS Zone.Identifier
*:Zone.Identifier

# -----------------------------------------------------------------------------
# 临时文件和日志
# ------------------------------------------------------------------------------

# 临时文件
*.tmp
*.temp
*.bak
*.backup
*.orig

# 日志文件
*.log
*.logs

# 调试核心转储
core
core.*
vgcore.*

# 性能分析
gmon.out
perf.data
perf.data.old