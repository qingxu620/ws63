#===============================================================================
# @brief WS63 structured SLE laser TX Kconfig
#===============================================================================

menu "WS63 SLE TX 离线任务发送板配置"
    depends on ENABLE_LASER_SLE_JOB_SAMPLE

config LASER_SLE_JOB_TRANSMITTER
    bool "构建发射板固件（TX：串口输入转SLE包）"
    default y
    help
        选择构建发射板（TX）固件。
        发射板从串口读取PC上位机的自定义协议数据，
        封装为SLE结构化包发送给接收板。不模拟Grbl协议。

comment "当前构建目标：发射板固件（TX）"
    depends on LASER_SLE_JOB_TRANSMITTER

comment "发射板串口配置（连接PC上位机）"
config LASER_SLE_JOB_UART_BAUD
    int "PC上位机串口波特率"
    range 9600 1000000
    default 115200
    help
        设置发射板与PC上位机通信的串口波特率。
        默认115200，需与上位机设置一致。

config LASER_SLE_JOB_UART_BUS
    int "PC上位机串口总线号"
    default 1
    help
        设置使用的UART总线编号（0, 1, 2）。
        默认使用UART1。

config LASER_SLE_JOB_UART_TX_PIN
    int "PC上位机串口TX引脚"
    default 15
    help
        设置串口发送引脚的GPIO编号。
        默认GPIO15，需与硬件连接一致。

config LASER_SLE_JOB_UART_RX_PIN
    int "PC上位机串口RX引脚"
    default 16
    help
        设置串口接收引脚的GPIO编号。
        默认GPIO16，需与硬件连接一致。

endmenu
