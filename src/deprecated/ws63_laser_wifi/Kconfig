menu "WS63 WiFi 实时激光打标配置"

config LASER_WIFI_AP_SSID
    string "WiFi 热点名称（SSID）"
    default "WS63_LASER_WIFI"
    help
        设置激光控制器创建的WiFi热点名称。
        设备将以此名称广播，供电脑或手机连接。

config LASER_WIFI_AP_PSK
    string "WiFi 热点密码"
    default "12345678"
    help
        设置WiFi热点的WPA/WPA2密码。
        密码长度至少8位，建议使用强密码保障安全。

config LASER_WIFI_AP_CHANNEL
    int "WiFi 热点信道"
    range 1 13
    default 13
    help
        设置WiFi热点使用的信道。
        信道1-13可选，建议选择干扰较少的信道。
        默认使用信道13。

config LASER_WIFI_TCP_PORT
    int "TCP 服务端口"
    default 5000
    help
        设置TCP服务器监听的端口号。
        LaserGRBL通过Telnet协议连接此端口进行通信。
        默认端口5000，可根据需要修改。

config LASER_WIFI_WORK_AREA_X_MM
    int "X轴工作区域（mm）"
    default 70

config LASER_WIFI_WORK_AREA_Y_MM
    int "Y轴工作区域（mm）"
    default 70

config LASER_WIFI_STATUS_PERIODIC
    bool "启用周期性状态报告"
    default n
    help
        启用后，控制器在连接状态下会定期发送Grbl状态报告。
        通常LaserGRBL会主动发送'?'查询状态，此选项一般不需要开启。

endmenu
