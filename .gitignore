# 链接器脚本生成文件
*.lds
*.ld

# 预处理器输出
*.i
*.ii
*.s
*.asm

# 依赖文件
*.d
*.dep

# 编译数据库
compile_commands.json
compile_flags.txt

# ccache 缓存
.ccache/
.ccache_*

